# ───── Comum ─────
NODE_ENV=production
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@db:5432/sarai
REDIS_URL=redis://redis:6379
PGCRYPTO_KEY=change-me-32-bytes-minimum-please
JWT_SECRET=change-me-32-bytes-minimum-please
HELENA_HMAC_SECRET=shared-with-helena-custom-menu
ADMIN_API_KEY=change-me-admin-token
PUBLIC_BASE_URL=https://api.suaplataforma.com

# ───── panel-api ─────
PANEL_PORT=8787

# ───── engine ─────
ENGINE_PORT=8788
WEBHOOK_DEBOUNCE_MS=20000

# ───── scheduler ─────
SCHEDULER_TZ=America/Sao_Paulo

# ───── LLM defaults (overridable per account) ─────
OPENROUTER_DEFAULT_MODEL=x-ai/grok-4-fast
SPLITTER_MODEL=x-ai/grok-4-fast
