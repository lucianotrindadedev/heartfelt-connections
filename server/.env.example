# ───── Comum ─────
NODE_ENV=production
LOG_LEVEL=info

# Postgres do Supabase self-hosted (porta 5432 do container db).
# Em produção (dentro do docker-compose, mesmo host do Supabase): use o hostname do container.
# Fora dele (debug local da VPS): use o IP/host público do Postgres + porta exposta.
# Substitua <SENHA> e <HOST> pelos valores reais (NÃO commitar este arquivo com segredos).
DATABASE_URL=postgres://postgres:<SENHA>@<HOST>:5432/postgres

# Redis (BullMQ + cache). Subido pelo docker-compose.
REDIS_URL=redis://redis:6379

# Chaves do Supabase self-hosted — usadas SE você for falar com PostgREST/Storage/Auth via HTTP.
# Para o backend Sarai, normalmente só DATABASE_URL é necessária (acesso direto ao Postgres).
SUPABASE_URL=http://supabasekong-<seu-id>.sslip.io
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───── Segredos da plataforma Sarai (gere novos, não reutilize do Supabase) ─────
PGCRYPTO_KEY=change-me-32-bytes-minimum-please
JWT_SECRET=change-me-32-bytes-minimum-please
HELENA_HMAC_SECRET=shared-with-helena-custom-menu
ADMIN_API_KEY=change-me-admin-token
PUBLIC_BASE_URL=https://api.suaplataforma.com

# ───── panel-api ─────
PANEL_PORT=8787

# ───── engine ─────
ENGINE_PORT=8788
WEBHOOK_DEBOUNCE_MS=20000

# ───── scheduler ─────
SCHEDULER_TZ=America/Sao_Paulo

# ───── LLM defaults (overridable per account) ─────
OPENROUTER_DEFAULT_MODEL=x-ai/grok-4-fast
SPLITTER_MODEL=x-ai/grok-4-fast

# ───── Google OAuth (para Google Calendar) ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
